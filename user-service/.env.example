# --- App Configuration ---
APP_NAME=user-service
APP_ENV=development             # development, production, test
PORT=8080
TIMEZONE=UTC
SIGNATURE_KEY=your_secret_signature_key_here    # Used for API Key SHA256 validation

# --- Database Configuration (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ms_user_service
DB_USERNAME=postgres
DB_PASSWORD=password
DB_SSL_MODE=disable             # disable, require, verify-ca, verify-full
DB_MAX_OPEN_CONNECTION=100
DB_MAX_IDLE_CONNECTION=10
DB_MAX_LIFETIME=3600            # in seconds
DB_MAX_IDLE_TIME=1800           # in seconds

# --- JWT Configuration ---
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_EXPIRATION_TIME=3600        # in seconds (e.g., 3600 = 1 hour)
JWT_ISSUER=mini-soccer

# --- Rate Limiter Configuration ---
RATE_LIMITER_MAX_REQUEST=5.0    # maximum requests per second
RATE_LIMITER_TIME_SECOND=1      # time window in seconds

# --- Consul Configuration (Optional) ---
# CONSUL_HTTP_URL=http://localhost:8500
# CONSUL_HTTP_KEY=config/user-service
# CONSUL_HTTP_TOKEN=
# CONSUL_WATCH_INTERVAL_SECONDS=30
